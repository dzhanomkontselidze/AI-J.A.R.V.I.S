    {
      "parameters": {
        "jsCode": "const text = $input.first().json.output;\n\nconst clean = text\n  .replace(/\\*\\*/g, '')\n  .replace(/\\*/g, '')\n  .replace(/\\_\\_/g, '')\n  .replace(/\\_/g, '')\n  .replace(/\\[/g, '')\n  .replace(/\\]/g, '')\n  .replace(/\\`/g, '')\n  .replace(/\\#/g, '')\n  .replace(/\\{/g, '')\n  .replace(/\\}/g, '')\n  .replace(/\\(/g, '')\n  .replace(/\\)/g, '')\n  .replace(/\\>/g, '')\n  .replace(/\\!/g, '');\n\nreturn [{ json: { cleaned_text: clean } }];"
      },
